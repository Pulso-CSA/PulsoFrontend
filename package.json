{
  "name": "pulso-desktop",
  "private": true,
  "version": "0.0.33",
  "type": "module",
  "description": "Pulso - Dashboard Operacional Inteligente",
  "author": "Pulso Tech",
  "scripts": {
    "postinstall": "node scripts/postinstall-build-icon.cjs",
    "preelectron:dev": "node scripts/build-icon.cjs",
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:icon": "node scripts/build-icon.cjs",
    "sync:csa-api": "node scripts/sync-pulso-csa-api.cjs",
    "bundle:csa-runtime": "node scripts/bundle-csa-runtime.cjs",
    "prebuild:electron": "node scripts/bundle-csa-runtime.cjs",
    "prebuild:electron:publish": "node scripts/bundle-csa-runtime.cjs",
    "build:electron": "node scripts/kill-electron-processes.cjs && npm run build:icon && vite build && electron-builder --win --publish never",
    "build:electron:open": "npm run build:electron && node scripts/open-installer.cjs",
    "open:installer": "node scripts/open-installer.cjs",
    "build:electron:publish": "node scripts/kill-electron-processes.cjs && npm run build:icon && vite build && electron-builder --win --publish always",
    "electron:dev": "wait-on http://localhost:8080 && electron .",
    "installer:dev": "cd installer && npm run installer:dev",
    "dev:app": "concurrently -k \"npm run dev\" \"npm run electron:dev\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.1.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.10.10",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-i18next": "^16.6.6",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "lovable-tagger": "^1.1.11",
    "postcss": "^8.5.6",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "wait-on": "^8.0.1"
  },
  "main": "electron/main.cjs",
  "build": {
    "afterPack": "./scripts/after-pack.cjs",
    "appId": "com.pulso.app",
    "productName": "Pulso",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "pulso-icon.ico"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Pulso-CSA",
      "repo": "PulsoFrontend",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Pulso-Setup-${version}.${ext}"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Pulso"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "public/App.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "public/App.png"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    }
  }
}
