# Destino do proxy do Vite em npm run dev (PulsoAPI). Se a API estiver noutra porta:
# VITE_DEV_API_PROXY=http://127.0.0.1:8000
#
# Backend local (fallback quando não estás em localhost:8080 — ex. Electron empacotado)
# VITE_API_URL=http://127.0.0.1:8000
# Produção / omissão no build:
VITE_API_URL=https://pulsoapi-production-f227.up.railway.app
VITE_VERSION_CHECK_ENABLED=true
VITE_VERSION_CHECK_INTERVAL_MS=3600000
# URLs dos instaladores (tela /download). Exemplos:
# VITE_DOWNLOAD_URL_WINDOWS=https://releases.pulso.tech/Pulso-Setup-1.0.0.exe
# VITE_DOWNLOAD_URL_LINUX=https://releases.pulso.tech/Pulso-Setup-1.0.0.AppImage
# VITE_DOWNLOAD_URL_MAC=https://releases.pulso.tech/Pulso-Setup-1.0.0.dmg
