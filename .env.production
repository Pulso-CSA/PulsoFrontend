# Por omissão = API local (igual ao .env). Em deploy na cloud, define na CI:
#   VITE_API_URL=https://sua-api.exemplo.com npm run build
# ou cria .env.production.local (não commitar) com a URL real.
VITE_API_URL=http://127.0.0.1:8000
VITE_VERSION_CHECK_ENABLED=true
VITE_VERSION_CHECK_INTERVAL_MS=3600000
